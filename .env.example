# ═══════════════════════════════════════════════════════════════════════════
# PinGuru Frontend Environment Variables (.env.example)
# 
# IMPORTANT: Copy this file to .env.local and fill in the actual values.
# NEVER commit environment files to git (they may contain sensitive config).
# ═══════════════════════════════════════════════════════════════════════════

# Backend API Configuration
VITE_API_URL=http://localhost:8000
VITE_API_PRODUCTION_URL=https://api.pinguru.me

# Google OAuth Configuration (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# App Configuration
VITE_APP_NAME=PinGuru
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development
